APP_NAME=TrafficGuard AI
APP_VERSION=1.0.0
DEBUG=true

# SQLite for development (change to PostgreSQL for production)
DATABASE_URL=sqlite+aiosqlite:///./trafficguard.db

# Model confidence thresholds (tune per environment)
CONF_GENERAL=0.45
CONF_HELMET=0.40
CONF_SEATBELT=0.40
CONF_PLATE=0.35
NMS_IOU=0.50

# CORS — add your frontend URL here
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
